# Example environment configuration for the prompt engineer portfolio

# Copy this file to `.env` and fill in your own values before running
# the services locally.  These environment variables are used by the
# httpx client to authenticate with your chosen language model API.

# URL of the cloud language model
LLM_API_URL=https://example.com/v1/generate

# API key for the cloud language model
LLM_API_KEY=your_api_key_here